{
  "expo": {
    "name": "AI Dehazing Complete",
    "slug": "dehazing-complete-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "dehazing",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "bundleIdentifier": "com.yourname.dehazingapp",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "AI Dehazing app needs camera access to capture video frames for processing.",
        "NSMicrophoneUsageDescription": "Required for video recording with audio.",
        "NSPhotoLibraryUsageDescription": "Access to photo library to select videos for dehazing."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET"
      ],
      "package": "com.yourname.dehazingapp"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AI Dehazing to access your camera for video capture."
        }
      ],
      "expo-font",
      "expo-router",
      "react-native-vision-camera"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}